# Copy to .secrets and fill in real values.
# .secrets is gitignored — never commit it.
# Used by `act` to run CI locally (see README for setup).

TEST_GMAIL_REFRESH_TOKEN=
TEST_GMAIL_EMAIL=claven.test.inbox@gmail.com
PUBSUB_TOPIC=projects/claven-prod/topics/<topic-name>
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=

# Backend deploy secrets (only needed if testing the deploy workflow locally)
# DATABASE_URL=
# GCP_PROJECT_ID=
# GCP_SERVICE_ACCOUNT=
# GCP_WORKLOAD_IDENTITY_PROVIDER=
# INTERNAL_API_SECRET=
# OAUTH_REDIRECT_URI=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Local development environment — copy to .env.local and fill in values.
# .env.local is gitignored — never commit it.
# Used by `make dev` to start the backend and frontend together.
#
# The backend runs at http://localhost:8000
# The frontend runs at http://localhost:3000
#
# PREREQUISITE: register http://localhost:8000/oauth/callback as an
# authorized redirect URI in your GCP OAuth client before running OAuth locally.

# Neon dev branch — used by `make dev` (write access, isolated from prod)
DATABASE_URL=postgresql://...

# Neon prod DB read-only role — used by `make dev-read-only`
# Connects to prod with SELECT-only permissions so you can observe live state
# without risking writes. Create with: scripts/create_readonly_role.sql
DATABASE_URL_READONLY=postgresql://claven_readonly:<password>@<prod-pooler-host>/neondb?sslmode=require

# From GCP OAuth client credentials
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Fixed for local dev
OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
FRONTEND_URL=http://localhost:3000

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=

# Can be anything locally — only used to protect /internal/* endpoints
INTERNAL_API_SECRET=dev-internal-secret

# Pub/Sub topic (only needed for live Gmail push tests locally)
PUBSUB_TOPIC=projects/claven-prod/topics/gmail-push
